{
  "name": "golden-universe-visualizer",
  "private": true,
  "version": "1.0.2",
  "description": "Interactive visualization and exploration of the Golden Ratio and its mathematical properties",
  "author": "Golden Universe Team",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:with-types": "tsc -b && vite build",
    "build:production": "NODE_ENV=production npm run build",
    "build:staging": "NODE_ENV=staging npm run build",
    "build:analyze": "npm run build && open dist/stats.html",
    "preview": "vite preview",
    "preview:production": "vite preview --mode production",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss,css,json}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --dir src --exclude \"**/e2e/**\" --exclude \"**/integration/**\"",
    "test:integration": "vitest run src/test/integration",
    "test:accessibility": "vitest run src/test/accessibility",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:accessibility && npm run test:e2e",
    "test:ci": "npm run lint && npm run type-check && npm run test:coverage && npm run test:e2e",
    "parse-content": "node scripts/quick-parse.js",
    "parse-content:full": "tsx scripts/parse-content.ts",
    "index": "npm run parse-content",
    "generate-icons": "node scripts/generate-icons.js",
    "server": "ts-node --project tsconfig.server.json server/server.ts",
    "server:dev": "nodemon --watch server --ext ts --exec ts-node --project tsconfig.server.json server/server.ts",
    "server:build": "tsc --project tsconfig.server.json",
    "server:start": "node server/dist/server.js",
    "db:seed": "ts-node --project tsconfig.server.json server/database/seed.ts",
    "db:init": "ts-node --project tsconfig.server.json -e \"require('./server/database/schema').initDatabase()\"",
    "start:all": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "start": "npm run start:all",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod",
    "clean": "rm -rf dist node_modules/.vite"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@types/d3": "^7.4.3",
    "@types/dompurify": "^3.0.5",
    "@types/react-window": "^1.8.8",
    "axios": "^1.13.5",
    "better-sqlite3": "^11.10.0",
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "flexsearch": "^0.8.212",
    "helmet": "^8.1.0",
    "highlight.js": "^11.11.1",
    "idb": "^8.0.3",
    "intro.js": "^8.3.2",
    "katex": "^0.16.33",
    "leva": "^0.10.1",
    "marked": "^15.0.12",
    "morgan": "^1.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "react-window": "^2.2.7",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.97.3",
    "swagger-ui-express": "^5.0.1",
    "three": "^0.183.1",
    "vite-plugin-compression": "^0.5.1",
    "workbox-window": "^7.4.0",
    "ws": "^8.19.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/flexsearch": "^0.7.6",
    "@types/intro.js": "^5.1.5",
    "@types/katex": "^0.16.8",
    "@types/marked": "^5.0.2",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.18",
    "axe-core": "^4.11.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
    "msw": "^2.12.10",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "terser": "^5.46.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^4.5.5",
    "vitest": "^4.0.18",
    "vitest-canvas-mock": "^1.1.3",
    "whatwg-fetch": "^3.6.20"
  },
  "overrides": {
    "zustand": "^4.5.5"
  }
}
